MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.exqcxui.mongodb.net/ace_finance?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=your-long-random-secret-here
PORT=3001
FRONTEND_URL=http://localhost:3000

# Gmail SMTP (recommended for local/dev)
# 1. Enable 2-Step Verification on the Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character app password into SMTP_PASS (spaces optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your.gmail@gmail.com

# Supabase Storage (REQUIRED — invoices + payment receipts; no local disk)
# Project Settings → API → Project URL + service_role key (secret)
# Storage → create a PRIVATE bucket named ace-finance-files
# If upload fails, expense/payment is NOT saved to MongoDB
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=ace-finance-files
